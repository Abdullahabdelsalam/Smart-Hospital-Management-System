<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>

    <session-factory>

        <!-- Database Connection -->
        <property name="hibernate.connection.driver_class">
            com.mysql.cj.jdbc.Driver
        </property>

        <property name="hibernate.connection.url">
            jdbc:mysql://localhost:3306/hospital_db
        </property>

        <property name="hibernate.connection.username">
            root
        </property>

        <property name="hibernate.connection.password">
            1111
        </property>

        <!-- SQL Dialect -->
        <property name="hibernate.dialect">
            org.hibernate.dialect.MySQLDialect
        </property>

        <!-- Auto Table Creation -->
        <property name="hibernate.hbm2ddl.auto">
            update
        </property>

        <!-- Show SQL -->
        <property name="hibernate.show_sql">
            true
        </property>

        <property name="hibernate.format_sql">
            true
        </property>

        <!-- First + Second Level Cache -->
        <property name="hibernate.cache.use_second_level_cache">
            true
        </property>

        <property name="hibernate.cache.region.factory_class">
            org.hibernate.cache.jcache.JCacheRegionFactory
        </property>

        <mapping class="com.abdullah.entity.Person"/>
        <mapping class="com.abdullah.entity.Doctor"/>
        <mapping class="com.abdullah.entity.Patient"/>
        <mapping class="com.abdullah.entity.Admin"/>
        <mapping class="com.abdullah.entity.MedicalRecord"/>
        <mapping class="com.abdullah.entity.Specialization"/>
        <mapping class="com.abdullah.entity.Appointment"/>


    </session-factory>

</hibernate-configuration>